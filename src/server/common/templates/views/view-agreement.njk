{% set bodyClasses = "view-offer-page" %}
{% set mainClasses = "" %}
{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block main %}
  <div class="govuk-width-container">
    {% block beforeContent %}{% endblock %}

    <nav class="govuk-breadcrumbs" aria-label="Breadcrumb">
      <ol class="govuk-breadcrumbs__list">
        <li class="govuk-breadcrumbs__list-item">
          <a class="govuk-breadcrumbs__link" href="home">Home</a>
        </li>
      </ol>
    </nav>

    <main class="govuk-main-wrapper" id="main-content" role="main">
      {% block content %}

        <div class="govuk-!-margin-top-4" style="display: flex; justify-content: space-between; align-items: baseline;">
          <span id="farmName" class="govuk-body govuk-!-font-size-19" style="margin-bottom: 0;">
            <strong>{{ company }}</strong>
          </span>
          <span id="farmerName" class="govuk-body govuk-!-font-size-19" style="margin-bottom: 0; margin-top: -23px;">
            <strong>Alfred Waldron</strong>
          </span>
        </div>

        <div id="sbi" class="govuk-body govuk-!-font-size-16 govuk-!-margin-top-1" style="margin-bottom: 0; padding-top: 0; padding-bottom: 0; line-height: 1;">
          Single business identifier (SBI): {{ sbi }}
        </div>

        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

        <div class="govuk-grid-row">
          <div class="govuk-grid-column-two-thirds">
            <h1 class="govuk-heading-xl">
              Agile Farm agreement
            </h1>

            <dl class="govuk-body dataset-info">
              <dd>Agreement holder:</dd>
              <dt>{{ company }}</dt>

              <dd>SBI:</dd>
              <dt>{{ sbi }}</dt>

              <dd>Address:</dd>
              <dt>{{ address }}</dt>

              <dd>Agreement name:</dd>
              <dt>{{ agreementName }}</dt>

              <dd>Agreement number:</dd>
              <dt>{{ agreementNumber }}</dt>

              <dd>Start date:</dd>
              <dt>{{ agreementStartDate | formatDate }}</dt>
            </dl>
          </div>
        </div>

        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <div class="govuk-grid-row">
          <div class="govuk-grid-column-one-quarter">
            <nav role="navigation" aria-labelledby="subsection-title">
              <div id="contents">
                <p class="govuk-body-s">Contents</p>
                <ul class="govuk-list toc">
                  <li><a href="#intro">1. Introduction and overview</a></li>
                  <li><a href="#parties">2. Parties to the agreement</a></li>
                  <li><a href="#land">3. Land covered by agreement</a></li>
                  <li><a href="#actions">4. Summary of parcel-based actions</a></li>
                  <li><a href="#payment">5. Summary of payments</a></li>
                  <li><a href="#schedule">6. Annual payment schedule</a></li>
                  <li><a href="#sign">7. Electronic signature</a></li>
                </ul>
              </div>
            </nav>
          </div>

          <div class="govuk-grid-column-three-quarters">
            <h2 id="intro" class="govuk-heading-l">1. Introduction and Overview</h2>
            <p class="govuk-body">
              This is the Sustainable Farming Incentive (SFI) "Agreement Document", which describes the sum to be paid (the "Grant") to the agreement holder ("you") for delivering the SFI action(s) (the "Actions") you have chosen and for entering into and managing your Agreement (the "SFI Management Payment").
            </p>

            <p>The SFI "Agreement" comprises:</p>
            <ul class="govuk-list govuk-list--bullet">
              <li>This Agreement Document;</li>
              <li>The Sustainable Farming Incentive Agreement "Terms and Conditions", which are applicable to the payment of the Grant;</li>
              <li>The Actions you have chosen.</li>
            </ul>

            <p class="govuk-body">
              When you enter the Agreement, you are agreeing to the terms applicable to the payment of the Grant. You should review the mandatory requirements of your Agreement to make sure you understand the full extent of your obligations under the Agreement.
            </p>

            <h2 id="parties" class="govuk-heading-l">2. Parties to the Agreement</h2>
            <p class="govuk-body">This Agreement is between:</p>
            <ul class="govuk-list">
              <li>You, the agreement holder;</li>
              <li>{{ company }}, of {{ address }}, {{ postcode }};</li>
              <li>The Rural Payments Agency (acting as a delivery body on behalf of the Department for Environment, Food and Rural Affairs), PO Box 324, Worksop, S95 1DF ("us", "we", "our").</li>
            </ul>

            <h2 id="land" class="govuk-heading-l">3. Land covered by agreement</h2>
            <p class="govuk-body">The "Agreement Land" comprises the following land parcels:</p>

            {{ govukTable({
              captionClasses: "govuk-table__caption--m",
              classes: "govuk-table--small-text-until-tablet",
              head: agreementLand.headings,
              rows: agreementLand.data
            }) }}

            <p class="govuk-body">
              Please note that the Terms and Conditions contain separate obligations in relation to the Agreement Land.
            </p>

            <h2 class="govuk-heading-l">4. Summary of parcel-based actions</h2>
            <p class="govuk-body">The following table sets out a summary of the Parcel based SFI Actions you have chosen and agree to complete under the Agreement. The Terms and Conditions and the Actions set out the accompanying obligations for the chosen Actions.</p>
            <table class="table-bordered">
                {{ govukTable({
                    captionClasses: "govuk-table__caption--m",
                    classes: "govuk-table--small-text-until-tablet",
                    head: summaryOfActions.headings,
                    rows: summaryOfActions.data
                    })
                }}
            </table>

            <h2 class="govuk-heading-l">5. Summary of payments</h2>
            <p class="govuk-body">Subject to you complying with your Agreement, the table below sets out a summary of:</p>
            <ul class="govuk-list govuk-list--bullet">
                <li>the total payments for the Actions you have chosen and agree to complete under the Agreement.</li>
                <li>the relevant additional payments</li>
                <li>the indicative SFI management payment - if you have submitted 2 or more SFI applications, the SFI management payment may be removed from this agreement offer as it will only be paid for the area, up to 50 hectares, entered into SFI actions in the 'live' SFI agreement which starts first</li>
            </ul>

            <p class="govuk-body">These payments will be made each year of your Agreement.</p>
            <p class="govuk-body">Please note that these figures are correct as at the Agreement Start Date and may vary as a result of the processes set out in the Terms and Conditions.</p>

            <table class="table-bordered">
                {{ govukTable({
                    captionClasses: "govuk-table__caption--m",
                    classes: "govuk-table--small-text-until-tablet",
                    head: summaryOfPayments.headings,
                    rows: summaryOfPayments.data
                    })
                }}
            </table>

            <h2 class="govuk-heading-l">6. Annual Payment Schedule</h2>
            <p class="govuk-body">Subject to you complying with your Agreement, the table below sets out a summary of the total payments for:</p>
            <ul class="govuk-list govuk-list--bullet">
                <li>each year of the Agreement</li>
                <li>the total for the duration of the Agreement</li>
            </ul>
            
            <p class="govuk-body">Please note that these figures are correct as at the Agreement Start Date and may vary as a result of the processes set out in the Terms and Conditions.</p>
            
            <table class="table-bordered">
                {{ govukTable({
                    captionClasses: "govuk-table__caption--m",
                    classes: "govuk-table--small-text-until-tablet",
                    head: annualPaymentSchedule.headings,
                    rows: annualPaymentSchedule.data
                    })
                }}
            </table>
            
            <p class="govuk-body">If you are eligible for the Management Payment (MPAY1) the payment details will be shown within section 7 below.</p>

            <h2 id="sign" class="govuk-heading-l">7. Electronic signature</h2>
            {% if status === 'offered' %}
              <p class="govuk-body">This Agreement has not been signed by anyone representing {{ company }}.</p>
            {% elif status === 'accepted' %}
              <p class="govuk-body">
                The Agreement comprising this Agreement Document, the Terms and Conditions and the Actions was accepted by {{ username }} - {{ company }} on {{ signatureDate | formatDate }}
              </p>
            {% endif %}

            <h2 class="govuk-heading-l">Data Protection</h2>
            <p class="govuk-body">
              The Department for Environment, Food and Rural Affairs (Defra) is the data controller for personal data you give to RPA. For information on how we handle personal data go to www.gov.uk and search 'Rural Payments Agency personal information charter'.
            </p>
          </div>
        </div>

      {% endblock %}
    </main>
  </div>
{% endblock %}